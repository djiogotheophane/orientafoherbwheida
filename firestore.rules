rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for the 'products' collection
    match /products/{productId} {
      // Anyone can read products (public storefront)
      allow read: if true;
      
      // Valid write payloads are allowed for managing products
      allow create, update: if request.resource.data.id is string &&
                              request.resource.data.name is string &&
                              request.resource.data.category is string;
                              
      allow delete: if true;
    }
  }
}
